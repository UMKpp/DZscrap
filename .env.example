# Redis Configuration (Broker and Result Backend)
REDIS_URL=redis://<your-redis-host>:<port>/0

# Database Configuration (SQLite default or Postgres)
DATABASE_URL=sqlite:///./storage/db.sqlite3

# Storage Paths
STORAGE_DIR=./storage

# Allowed Origins for CORS
ALLOWED_ORIGINS=chrome-extension://<your-extension-id>,https://<your-production-domain>.com
