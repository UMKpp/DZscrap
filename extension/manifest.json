{
  "manifest_version": 3,
  "name": "Image Scraper Pro - Dataset Builder",
  "version": "1.0.0",
  "description": "Local image scraping tool that builds ML-ready datasets using your own backend server.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://*.onrender.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}